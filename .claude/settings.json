{
  "permissions": {
    "allow": [
      "mcp__infisical__list-projects",
      "mcp__infisical__list-secrets",
      "mcp__infisical__get-secret",
      "mcp__infisical__create-secret",
      "Bash(scripts/infisical-ensure-secret.mjs *)",
      "Bash(./scripts/infisical-ensure-secret.mjs *)",
      "Bash(node scripts/infisical-ensure-secret.mjs *)"
    ],
    "ask": [
      "mcp__infisical__update-secret",
      "mcp__infisical__delete-secret"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
          }
        ]
      }
    ]
  }
}
