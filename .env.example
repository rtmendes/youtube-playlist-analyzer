# Server
NODE_ENV=development
PORT=3000

# Database – Postgres (required). Use your Supabase connection string.
# Supabase: Project Settings → Database → Connection string (URI).
# Example: postgresql://postgres.[ref]:[password]@[host]:5432/postgres
DATABASE_URL=

# Auth (e.g. Manus / OAuth)
JWT_SECRET=
OAUTH_SERVER_URL=
OWNER_OPEN_ID=
VITE_APP_ID=

# Optional: Supabase (for client-side auth/storage or when using Supabase Postgres as DB)
# From Supabase: Project Settings → API → Project URL and anon/service key
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Client-side Supabase (exposed to browser) – only if using Supabase Auth/Realtime
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=

# Forge API (Map / NLP)
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
