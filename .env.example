# Server
NODE_ENV=development
PORT=3000

# Database – Postgres (required). Use your Supabase connection string.
# Supabase: Project Settings → Database → Connection string (URI).
# Example: postgresql://postgres.[ref]:[password]@[host]:5432/postgres
DATABASE_URL=

# Auth (e.g. Manus / OAuth)
# Leave OAUTH_SERVER_URL empty to enable single-user auto-auth (no login screen).
JWT_SECRET=
OAUTH_SERVER_URL=
OWNER_OPEN_ID=
VITE_APP_ID=

# Optional: Supabase (for client-side auth/storage or when using Supabase Postgres as DB)
# From Supabase: Project Settings → API → Project URL and anon/service key
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Client-side Supabase (exposed to browser) – only if using Supabase Auth/Realtime
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=

# Forge API (Map / NLP)
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# API keys (recommended: set in .env so they work across computers/browsers)
# Get keys: see docs/API-KEYS.md
YOUTUBE_API_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
AMAZON_API_KEY=
AMAZON_API_PROVIDER=rainforest
GEMINI_API_KEY=
SCRAPECREATORS_API_KEY=
COMPOSIO_API_KEY=

# Optional: Website analytics (Umami). Leave empty to disable.
# Get these from your Umami dashboard (self-hosted or umami.is).
# VITE_ANALYTICS_ENDPOINT=https://analytics.example.com
# VITE_ANALYTICS_WEBSITE_ID=your-website-id
