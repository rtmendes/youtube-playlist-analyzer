# Server
NODE_ENV=development
PORT=3000

# Database – Postgres (required). Use your Supabase connection string.
# Supabase: Project Settings → Database → Connection string (URI).
# For Vercel/serverless use the pooler (port 6543) with ?pgbouncer=true
# Example: postgresql://postgres.[ref]:[password]@[host]:5432/postgres
DATABASE_URL=

# Auth (optional — leave OAUTH_SERVER_URL empty for single-user mode)
JWT_SECRET=
OAUTH_SERVER_URL=
OWNER_OPEN_ID=
VITE_APP_ID=

# LLM (Gemini via OpenAI-compatible endpoint)
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
LLM_API_KEY=
LLM_MODEL=gemini-2.5-flash
GEMINI_API_KEY=

# Supabase (Postgres DB + Storage for generated images)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
STORAGE_BUCKET=generated-images

# Optional S3 storage fallback (if not using Supabase Storage)
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=

# Gridbase export (POD pipeline)
GRIDBASE_BASE_URL=https://gridbase.insightprofit.live
GRIDBASE_API_KEY=
GRIDBASE_TABLE_ID=

# Client-side Supabase (only if using Supabase Auth/Realtime)
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=

# API keys — see docs/API-KEYS.md
YOUTUBE_API_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
AMAZON_API_KEY=
AMAZON_API_PROVIDER=rainforest
SCRAPECREATORS_API_KEY=
COMPOSIO_API_KEY=

# Optional analytics (Umami)
# VITE_ANALYTICS_ENDPOINT=
# VITE_ANALYTICS_WEBSITE_ID=

# Local dev with Infisical: infisical run --env=dev -- pnpm dev
# Or: pnpm dev:secrets
